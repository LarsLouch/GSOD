---
import { supabase } from '../lib/supabase';
import { onMount } from 'astro:components';
import { getCurrentUser, isAuthenticated } from '../lib/session';

let messages = [];
let newMessage = '';
let user = getCurrentUser();
let isLoading = true;
let isSending = false;

// Initialize messaging system
onMount(async () => {
 // Check if user is authenticated
 if (!isAuthenticated()) {
 window.location.href = '/login';
 return;
 }
 
 // Load message history
 await loadMessages();
 
 // Set up real-time listener for new messages
 const realTimeChannel = supabase
 .channel('messages-realtime')
 .on('postgres_changes', {
 event: 'INSERT',
 schema: 'public',
 table: 'messages'
 }, (payload) => {
 // Add new message to the list
 messages = [...messages, payload.new];
 
 // Scroll to bottom
 const messagesContainer = document.getElementById('messages-container');
 if (messagesContainer) {
 messagesContainer.scrollTop = messagesContainer.scrollHeight;
 }
 })
 .subscribe();
 
 // Set loading to false after initialization
 isLoading = false;
});

// Load message history
async function loadMessages() {
 const { data, error } = await supabase
 .from('messages')
 .select('*')
 .order('created_at', { ascending: true });
 
 if (error) {
 console.error('Error loading messages:', error);
 return;
 }
 
 messages = data;
}

// Send a new message
async function sendMessage() {
 if (!newMessage.trim() || isSending) return;
 
 isSending = true;
 
 const { data, error } = await supabase
 .from('messages')
 .insert([
 {
 sent_by: user.email,
 received_by: 'all', // For now, send to all users
 text: newMessage,
 created_at: new Date().toISOString()
 }
 ]);
 
 isSending = false;
 
 if (error) {
 console.error('Error sending message:', error);
 return;
 }
 
 // Clear input field
 newMessage = '';
}

// Format date
function formatDate(dateString) {
 const date = new Date(dateString);
 return date.toLocaleTimeString('pt-BR', {
 hour: '2-digit',
 minute: '2-digit'
 });
}
---

<Layout>
 <div class="messages-container">
 <header class="messages-header">
 <h1>Mensagens</h1>
 <button class="logout-btn" onclick="signOut()">Sair</button>
 </header>
 
 <div class="messages-content">
 {#if isLoading}
 <div class="loading">Carregando mensagens...</div>
 {:else}
 <div id="messages-container" class="messages-list">
 {#each messages as message}
 <div class="message {#if message.sent_by === user.email}sent{/if}">
 <div class="message-header">
 <span class="message-sender">{message.sent_by}</span>
 <span class="message-time">{formatDate(message.created_at)}</span>
 </div>
 <div class="message-body">
 {message.text}
 </div>
 </div>
 {/each}
 </div>
 {/if}
 
 <div class="message-input-container">
 <input
 type="text"
 bind:value={newMessage}
 placeholder="Digite sua mensagem..."
 on:keydown|preventDefault={async (e) => {
 if (e.key === 'Enter') {
 await sendMessage();
 }
 }}
 disabled={isSending}
 >
 <button
 class="send-btn"
 on:click={sendMessage}
 disabled={isSending || !newMessage.trim()}
 >
 {#if isSending}
 Enviando...
 {:else}
 Enviar
 {/if}
 </button>
 </div>
 </div>
 </div>
</Layout>
